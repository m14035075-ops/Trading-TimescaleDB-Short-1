# ===== OpenAlgo =====
OPENALGO_API_KEY=your_api_key_here
# OpenAlgo जिस machine पर चल रहा है उसका host (default: localhost)
OPENALGO_HOST=http://127.0.0.1:5000
OPENALGO_WS_PORT=8765

# ===== TimescaleDB / Postgres =====
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=marketdata
PG_USER=postgres
PG_PASSWORD=postgres

# ===== Recorder Settings =====
# कौन-सा data store करना है: quote / depth / both
RECORD_MODE=both
SYMBOLS_FILE=symbols.txt

# Batch size: इतनी rows जमा होने पर DB में flush
BATCH_SIZE=200
# या इतने seconds में force flush
FLUSH_INTERVAL_SEC=1.0

# Reconnect backoff (seconds)
RECONNECT_MIN=2
RECONNECT_MAX=60
